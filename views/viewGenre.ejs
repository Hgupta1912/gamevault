<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= genre.name %> Games — GameVault</title>
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/cards.css" />
  <link rel="stylesheet" href="/css/buttons.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <div class="container">
      <div class="page-header">
        <div style="display:flex; flex-direction:column; gap:0.4rem;">
          <span style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--text-muted);">Genre</span>
          <h1><span><%= genre.name %></span></h1>
        </div>
        <div style="display:flex; gap:0.75rem;">
          <a href="/genres/edit/<%= genre.id %>" class="btn btn--secondary">Edit Genre</a>
          <a href="/genres" class="btn btn--ghost">← All Genres</a>
        </div>
      </div>

      <% const games = genre.games ? genre.games.filter(g => g.id !== null) : [] %>

      <% if (games.length === 0) { %>
        <div class="empty-state">
          <p>No games in this genre yet.</p>
          <a href="/games/new" class="btn btn--primary">+ Add a Game</a>
        </div>
      <% } else { %>
        <div class="grid">
          <% games.forEach(game => { %>
            <div class="game-card" data-rating="<%= game.rating || 0 %>">
              <div class="game-card__image">
                <% if (game.cover_image) { %>
                  <img src="<%= game.cover_image %>" alt="<%= game.name %>" loading="lazy" />
                <% } else { %>
                  <span class="no-image">🎮</span>
                <% } %>
              </div>
              <div class="game-card__body">
                <a href="/games/<%= game.id %>">
                  <div class="game-card__title"><%= game.name %></div>
                </a>
              </div>
              <div class="game-card__footer">
                <span></span>
                <div class="stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <span class="star <%= i <= game.rating ? 'filled' : '' %>">★</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
