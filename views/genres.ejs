<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Genres — GameVault</title>
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/cards.css" />
  <link rel="stylesheet" href="/css/buttons.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <div class="container">
      <div class="page-header">
        <h1>All <span>Genres</span></h1>
        <a href="/genres/new" class="btn btn--primary">+ Add Genre</a>
      </div>

      <% if (genres.length === 0) { %>
        <div class="empty-state">
          <p>No genres yet. Add one to get started.</p>
          <a href="/genres/new" class="btn btn--primary">+ Add Genre</a>
        </div>
      <% } else { %>
        <div class="genre-grid">
          <% genres.forEach(genre => { %>
            <div class="genre-card" style="display:flex; flex-direction:column; gap:0.75rem; text-decoration:none;">
              <a href="/genres/<%= genre.id %>" style="text-decoration:none; flex:1; display:flex; align-items:center; justify-content:space-between;">
                <span class="genre-card__name"><%= genre.name %></span>
                <span class="genre-card__arrow">→</span>
              </a>
              <div style="display:flex; gap:0.5rem;">
                <a href="/genres/edit/<%= genre.id %>" class="btn btn--ghost btn--sm">Edit</a>
                <form action="/genres/delete/<%= genre.id %>" method="POST" class="delete-form"
                      onsubmit="return confirm('Delete genre <%= genre.name %>?')">
                  <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
