<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register — GameVault</title>
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/forms.css" />
  <link rel="stylesheet" href="/css/buttons.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <div class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
      <div style="max-width: 420px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 2rem;">
          <h1>Create an <span>Account</span></h1>
          <p>Join GameVault to manage your game library</p>
        </div>

        <% if (locals.error) { %>
          <div style="
            background: rgba(224, 92, 92, 0.1);
            border: 1px solid rgba(224, 92, 92, 0.3);
            border-radius: var(--radius);
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            color: var(--danger);
            font-size: 0.875rem;
          ">
            <%= error %>
          </div>
        <% } %>

        <div class="form-card" style="max-width: 100%;">
          <form action="/auth/register" method="POST">

            <div class="form-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                required
              />
            </div>

            <div class="form-group">
              <label for="password">Password</label>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="••••••••"
                required
              />
            </div> 

            <div class="form-group">
              <label for="confirm_password">Confirm Password</label>
              <input
                type="password"
                id="confirm_password"
                name="confirm_password"
                placeholder="••••••••"
                required
              />
            </div>

            <div class="form-actions" style="flex-direction: column; gap: 1rem;">
              <button type="submit" class="btn btn--primary" style="width: 100%; justify-content: center;">
                Create Account
              </button>
              <p style="text-align: center; font-size: 0.875rem;">
                Already have an account?
                <a href="/auth/login">Sign in</a>
              </p>
            </div>

          </form>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
